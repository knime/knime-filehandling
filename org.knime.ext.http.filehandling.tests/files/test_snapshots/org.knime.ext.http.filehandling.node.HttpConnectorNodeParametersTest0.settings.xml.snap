<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://www.knime.org/2008/09/XMLConfig" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.knime.org/2008/09/XMLConfig http://www.knime.org/XMLConfig_2008_09.xsd" key="test">
    <entry key="url" type="xstring" value="http://localhost"/>
    <entry key="followRedirects" type="xboolean" value="true"/>
    <entry key="sslIgnoreHostnameMismatches" type="xboolean" value="false"/>
    <entry key="sslTrustAllCertificates" type="xboolean" value="false"/>
    <config key="auth">
        <entry key="type" type="xstring" value="basic"/>
        <config key="basic">
            <entry key="use_credentials" type="xboolean" value="false"/>
            <entry key="credentials" type="xstring" isnull="true" value=""/>
            <entry key="user" type="xstring" value="Hewwo"/>
            <entry key="password" type="xpassword" value="02BQAAAGMq_QxveL1vZ0EBj-CFD46E1YAKsQ=="/>
        </config>
        <config key="none"/>
    </config>
    <entry key="connectionTimeout" type="xint" value="30"/>
    <entry key="readTimeout" type="xint" value="30"/>
</config>
